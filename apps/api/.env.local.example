# Anthropic API Key
# Get this from: https://console.anthropic.com/settings/keys
# Never commit your actual .env.local — add it to .gitignore
ANTHROPIC_API_KEY=sk-ant-...

# App Environment
NODE_ENV=development

# Shared app token — the mobile app must send this in the `x-app-token` header
# or the /api/analyze endpoint returns 401. Protects the public endpoint from
# abuse that would bill your Anthropic account. Must MATCH the mobile build's
# APP_TOKEN. Generate one with: openssl rand -hex 32
# If unset, the endpoint fails OPEN (no protection) — set it in Vercel.
APP_SHARED_TOKEN=

# === V1 (Supabase — not needed for V0) ===
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
